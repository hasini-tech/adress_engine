generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "fullTextIndex"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Client {
  id          BigInt   @id @default(autoincrement())
  client_id   String   @unique @db.VarChar(100)
  name        String   @db.VarChar(255)
  email       String?  @db.VarChar(255)
  phone       String?  @db.VarChar(50)
  company     String?  @db.VarChar(255)
  address     String?  @db.Text
  city        String?  @db.VarChar(100)
  state       String?  @db.VarChar(100)
  country     String?  @db.VarChar(100)
  postal_code String?  @db.VarChar(50)
  purchase_product String? @db.VarChar(500)
  purchase_amount  Decimal? @db.Decimal(12, 2)
  quality_score Int?
  quality_band  String?  @db.VarChar(50)
  metadata    Json?
  is_active   Boolean  @default(true)
  import_id   String?  @db.VarChar(100)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  @@index([email])
  @@index([phone])
  @@index([company])
  @@index([city])
  @@index([import_id])
  @@index([quality_band])
  @@fulltext([name, email, company, city])
  @@map("clients")
}

model ImportLog {
  id               Int       @id @default(autoincrement())
  import_id        String    @unique @db.VarChar(100)
  file_name        String?   @db.VarChar(255)
  file_size        BigInt?   @default(0)
  total_records    Int       @default(0)
  processed        Int       @default(0)
  inserted_records Int       @default(0)
  updated_records  Int       @default(0)
  failed_records   Int       @default(0)
  status           String    @default("pending") @db.VarChar(50)
  error_message    String?   @db.Text
  detected_schema  Json?
  field_mappings   Json?
  started_at       DateTime  @default(now())
  completed_at     DateTime?
  duration_ms      Int?      @default(0)

  @@index([status])
  @@index([started_at])
  @@map("import_logs")
}

model ScoringApiKey {
  id             Int       @id @default(autoincrement())
  apiKey         String    @db.Text
  apiKeyPreview  String?
  label          String?
  platform       String?
  platformKey    String    @default("custom") @db.VarChar(100)
  baseUrl        String?   @db.VarChar(500)
  exportPath     String?   @db.VarChar(255)
  authMode       String    @default("both") @db.VarChar(50)
  responsePath   String?   @db.VarChar(255)
  status         String    @default("saved")
  band           String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  customers      PlatformCustomer[]          // ← this line was missing

  @@map("scoring_api_keys")
}

model PlatformCustomer {
  id               Int           @id @default(autoincrement())
  scoringApiKeyId  Int
  scoringApiKey    ScoringApiKey @relation(fields: [scoringApiKeyId], references: [id], onDelete: Cascade)
  externalId       String?
  name             String?
  email            String?
  phone            String?
  address          String?       @db.Text
  city             String?
  state            String?
  purchaseProduct  String?       @db.VarChar(500)
  purchaseAmount   Decimal?      @db.Decimal(12, 2)
  rawData          String?       @db.LongText
  createdAt        DateTime      @default(now())

  @@unique([scoringApiKeyId, externalId])
  @@map("platform_customers")
}
